# Application Settings
APP_NAME=Delinoapp Products
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api/v1

# CORS Settings (JSON array)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database Settings
